generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// USER MODEL (JWT sessions - no Account/Session tables needed)
// ============================================================

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// none | pending | active — Pro is `active` (set after successful payment / webhook).
  subscriptionStatus String @default("none")

  /// Razorpay subscription ID for managing the subscription (cancel, etc.)
  razorpaySubscriptionId String?

  /// Provider cancellation is complete; paid Pro access remains until the period end.
  subscriptionCancelAtPeriodEnd Boolean   @default(false)
  subscriptionCurrentPeriodEnd  DateTime?

  portfolio            Portfolio?
  billingSubscriptions BillingSubscription[]
  billingCheckout      BillingCheckoutAttempt?
  billingPayments      BillingPayment[]

  @@map("users")
}

model BillingSubscription {
  id                     String    @id @default(uuid())
  userId                 String
  providerSubscriptionId String    @unique
  providerPlanId         String
  interval               String
  status                 String
  cancelAtPeriodEnd      Boolean   @default(false)
  currentPeriodEnd       DateTime?
  lastEventAt            DateTime?
  lastEventId            String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments BillingPayment[]

  @@index([userId, status])
  @@map("billing_subscriptions")
}

model BillingCheckoutAttempt {
  id                     String   @id @default(uuid())
  userId                 String   @unique
  providerSubscriptionId String?  @unique
  providerPlanId         String
  interval               String
  status                 String   @default("creating")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("billing_checkout_attempts")
}

model BillingPayment {
  providerPaymentId      String   @id
  userId                 String
  billingSubscriptionId  String
  providerSubscriptionId String
  status                 String
  createdAt              DateTime @default(now())

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription BillingSubscription @relation(fields: [billingSubscriptionId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([providerSubscriptionId])
  @@map("billing_payments")
}

model BillingWebhookEvent {
  providerEventId        String   @id
  eventType              String
  providerSubscriptionId String?
  occurredAt             DateTime
  processedAt            DateTime @default(now())

  @@index([providerSubscriptionId, occurredAt])
  @@map("billing_webhook_events")
}

// ============================================================
// PORTFOLIO MODELS
// ============================================================

model Portfolio {
  id     String  @id @default(uuid())
  userId String  @unique
  slug   String? @unique

  title     String  @default("")
  headline  String  @default("")
  summary   String  @default("") @db.Text
  avatarUrl String?
  resumeUrl String?

  templateId  String  @default("minimal")
  isPublished Boolean @default(false)

  metaTitle       String?
  metaDescription String?

  contactEmail String?
  phone        String?
  location     String?
  websiteUrl   String?

  customization Json @default("{}")

  /// Project IDs selected for Microlink live previews (compact; resolve liveUrl at render time).
  livePreviewProjectIds String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  experiences    Experience[]
  educations     Education[]
  skills         Skill[]
  projects       Project[]
  articles       Article[]
  socialProfiles SocialProfile[]
  certifications Certification[]
  achievements   Achievement[]
  customSections CustomSection[]
  views          PortfolioView[]

  @@index([slug])
  @@map("portfolios")
}

model PortfolioView {
  id          String   @id @default(uuid())
  portfolioId String
  viewedAt    DateTime @default(now())

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@index([portfolioId, viewedAt])
  @@map("portfolio_views")
}

model RateLimitBucket {
  key       String   @id
  count     Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([expiresAt])
  @@map("rate_limit_buckets")
}

model Experience {
  id          String    @id @default(uuid())
  portfolioId String
  company     String
  role        String
  description String    @db.Text
  startDate   DateTime?
  endDate     DateTime?
  location    String?
  logoUrl     String?
  sortOrder   Int       @default(0)

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@map("experiences")
}

model Education {
  id          String    @id @default(uuid())
  portfolioId String
  institution String
  degree      String
  field       String?
  description String?   @db.Text
  startDate   DateTime?
  endDate     DateTime?
  gpa         String?
  sortOrder   Int       @default(0)

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@map("educations")
}

model Skill {
  id          String @id @default(uuid())
  portfolioId String
  name        String
  category    String @default("general")
  level       Int?
  sortOrder   Int    @default(0)

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@map("skills")
}

model Project {
  id          String   @id @default(uuid())
  portfolioId String
  title       String
  description String   @db.Text
  imageUrl    String?
  liveUrl     String?
  sourceUrl   String?
  techStack   String[]
  featured    Boolean  @default(false)
  sortOrder   Int      @default(0)

  githubStars Int?
  githubForks Int?
  language    String?

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@map("projects")
}

model Article {
  id          String    @id @default(uuid())
  portfolioId String
  title       String
  description String    @db.Text
  url         String
  tags        String[]
  publishedAt DateTime?
  readTime    Int?
  sortOrder   Int       @default(0)

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@map("articles")
}

model SocialProfile {
  id          String  @id @default(uuid())
  portfolioId String
  platform    String
  url         String
  username    String?

  cachedStats Json?
  lastFetched DateTime?

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@unique([portfolioId, platform])
  @@map("social_profiles")
}

model Certification {
  id          String    @id @default(uuid())
  portfolioId String
  name        String
  issuer      String
  issueDate   DateTime?
  expiryDate  DateTime?
  url         String?
  sortOrder   Int       @default(0)

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@map("certifications")
}

model Achievement {
  id          String    @id @default(uuid())
  portfolioId String
  title       String    @db.Text
  date        DateTime?
  sortOrder   Int       @default(0)

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@map("achievements")
}

model CustomSection {
  id          String @id @default(uuid())
  portfolioId String
  sectionType String
  label       String
  items       Json   @default("[]")
  sortOrder   Int    @default(0)

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@unique([portfolioId, sectionType])
  @@map("custom_sections")
}

// ============================================================
// TEMPLATE REGISTRY (seeded)
// ============================================================

model Template {
  id          String @id
  name        String
  description String
  previewUrl  String
  category    String @default("general")

  @@map("templates")
}
